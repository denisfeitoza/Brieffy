            "text": "{\"session_id\":\"a9729d90-0968-42e9-a8df-2c25546a637a\",\"step_order\":15,\"question_type\":\"card_selector\",\"question_text\":\"Ops! Tivemos um problema para analisar sua resposta. Pode tentar novamente?\\n\\n**Pergunta original:** Qual é o principal diferencial da Vindia em relação ao ManyChat?\",\"options_offered\":[{\"title\":\"Preço mais acessível\",\"description\":\"Planos mais baratos que o concorrente\"},{\"title\":\"Facilidade de uso\",\"description\":\"Interface simples e intuitiva\"},{\"title\":\"Integração n8n\",\"description\":\"Automação avançada via n8n\"},{\"title\":\"Suporte personalizado\",\"description\":\"Atendimento dedicado ao cliente\"},{\"title\":\"Foco em PMEs brasileiras\",\"description\":\"Soluções adaptadas ao mercado local\"},{\"title\":\"Outro\",\"description\":\"Descreva seu próprio diferencial\"}],\"user_answer\":[\"Integração n8n\"],\"is_depth_question\":false}"
